#!/usr/bin/env bash
# No set -eu here: this file is sourced into the interactive shell

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SELF_DIR}/_find_completion.sh"
_comp="$(_find_completion systemctl)" && source "$_comp" || return
ME="$(basename "${BASH_SOURCE[0]}")"
complete -F _systemctl "${ME}"
